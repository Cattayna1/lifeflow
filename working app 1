function Toast({ msg }) {
  return msg ? <div className="toast">{msg}</div> : null;
}

function Toggle({ on, onToggle }) {
  return (
    <div
      onClick={onToggle}
      className="toggle-btn"
      style={{ background: on ? "var(--primary)" : "var(--border)" }}
    >
      <div className="toggle-thumb" style={{ left: on ? "23px" : "3px" }} />
    </div>
  );
}

