// ── Dashboard ────────────────────────────────────────────────────────────────
function Dashboard({ tasks, goals }) {
  const total = tasks.length, done = tasks.filter(t => t.completed).length;
  const rate = total ? Math.round((done / total) * 100) : 0;
  const stats = [
    { label: "Total Tasks", value: total, icon: "tasks", iconBg: "#EFF6FF", iconColor: "#1D4ED8", sub: `${done} completed` },
    { label: "Completion Rate", value: `${rate}%`, icon: "trend_up", iconBg: "#ECFDF5", iconColor: "#059669", sub: "This month" },
    { label: "Active Goals", value: goals.length, icon: "target", iconBg: "#FEF3C7", iconColor: "#D97706", sub: "In progress" },
    { label: "Streak", value: "7 days", icon: "star", iconBg: "#FFF1F2", iconColor: "#E11D48", sub: "Personal best!" },
  ];
  return (
    <div className="page-enter">
      <div className="stats-grid">
        {stats.map(s => (
          <div className="stat-card" key={s.label}>
            <div className="stat-icon" style={{ background: s.iconBg }}><Icon name={s.icon} size={20} color={s.iconColor} /></div>
            <div className="stat-label">{s.label}</div>
            <div className="stat-value">{s.value}</div>
            <div className="stat-sub">{s.sub}</div>
          </div>
        ))}
      </div>
      <div className="dash-grid">
        <div className="card">
          <div className="section-header">
            <div className="section-title">Recent Tasks</div>
            <span className="badge" style={{ background: "var(--primary-light)", color: "var(--primary)" }}>{total} total</span>
          </div>
          {tasks.slice(0, 5).map(t => (
            <div className="task-item" key={t.id}>
              <div className={`task-check ${t.completed ? "checked" : ""}`}>
                {t.completed && <Icon name="check" size={12} color="white" />}
              </div>
              <span className={`task-text ${t.completed ? "done" : ""}`}>{t.title}</span>
              <span className="badge" style={{ background: CATEGORY_COLORS[t.category]?.bg, color: CATEGORY_COLORS[t.category]?.text }}>{t.category}</span>
            </div>
          ))}
        </div>
        <div className="card">
          <div className="section-header"><div className="section-title">Goal Progress</div></div>
          <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
            {goals.map(g => {
              const pct = Math.min(100, Math.round((g.progress / g.target) * 100));
              return (
                <div key={g.id}>
                  <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 6, fontSize: 13 }}>
                    <span style={{ fontWeight: 600 }}>{g.title}</span>
                    <span style={{ color: "var(--text-muted)" }}>{pct}%</span>
                  </div>
                  <div className="progress-wrap">
                    <div className="progress-fill" style={{ width: `${pct}%`, background: pct >= 100 ? "var(--success)" : "var(--primary)" }} />
                  </div>
                  <div style={{ fontSize: 12, color: "var(--text-muted)", marginTop: 4 }}>{g.progress} / {g.target} {g.unit}</div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  );
}

// ── Tasks ────────────────────────────────────────────────────────────────────
function TasksPage({ tasks, setTasks, showToast }) {
  const [title, setTitle] = useState("");
  const [category, setCategory] = useState("Personal");
  const [dueDate, setDueDate] = useState("");
  const [priority, setPriority] = useState("medium");
  const [filter, setFilter] = useState("All");
  const [showForm, setShowForm] = useState(false);

  const addTask = () => {
    if (!title.trim()) return;
    setTasks(prev => [...prev, { id: Date.now(), title: title.trim(), category, completed: false, dueDate, priority }]);
    setTitle(""); setDueDate(""); setShowForm(false);
    showToast("✅ Task added!");
  };

  const toggle = (id) => setTasks(prev => prev.map(t => t.id === id ? { ...t, completed: !t.completed } : t));
  const del = (id) => { setTasks(prev => prev.filter(t => t.id !== id)); showToast("🗑️ Task removed"); };

  const cats = ["All", ...CATEGORIES];
  const filtered = filter === "All" ? tasks : tasks.filter(t => t.category === filter);
  const pending = filtered.filter(t => !t.completed);
  const done = filtered.filter(t => t.completed);

  return (
    <div className="page-enter">
      <div className="tabs" style={{ marginBottom: 24 }}>
        {cats.map(c => <button key={c} className={`tab ${filter === c ? "active" : ""}`} onClick={() => setFilter(c)}>{c}</button>)}
      </div>

      {showForm && (
        <div className="card" style={{ marginBottom: 20 }}>
          <div className="section-title" style={{ marginBottom: 16 }}>New Task</div>
          <div className="form-group">
            <label className="form-label">Task Title</label>
            <input className="form-input" placeholder="What needs to be done?" value={title} onChange={e => setTitle(e.target.value)} autoFocus />
          </div>
          <div className="form-row">
            <div className="form-group">
              <label className="form-label">Category</label>
              <select className="form-input" value={category} onChange={e => setCategory(e.target.value)}>
                {CATEGORIES.map(c => <option key={c}>{c}</option>)}
              </select>
            </div>
            <div className="form-group">
              <label className="form-label">Priority</label>
              <select className="form-input" value={priority} onChange={e => setPriority(e.target.value)}>
                {["high", "medium", "low"].map(p => <option key={p} value={p}>{p[0].toUpperCase() + p.slice(1)}</option>)}
              </select>
            </div>
          </div>
          <div className="form-group">
            <label className="form-label">Due Date</label>
            <input className="form-input" type="date" value={dueDate} onChange={e => setDueDate(e.target.value)} />
          </div>
          <div style={{ display: "flex", gap: 8 }}>
            <button className="btn btn-primary" onClick={addTask}>Add Task</button>
            <button className="btn btn-ghost" onClick={() => setShowForm(false)}>Cancel</button>
          </div>
        </div>
      )}

      {!showForm && (
        <button className="btn btn-primary" style={{ marginBottom: 20 }} onClick={() => setShowForm(true)}>
          <Icon name="plus" size={16} color="white" /> Add Task
        </button>
      )}

      <div className="card" style={{ marginBottom: 16 }}>
        <div className="section-header">
          <div className="section-title">Pending <span style={{ color: "var(--text-muted)", fontWeight: 400 }}>({pending.length})</span></div>
        </div>
        {pending.length === 0 && <div className="empty"><div className="empty-icon">🎉</div><div className="empty-title">All caught up!</div></div>}
        {pending.map(t => <TaskRow key={t.id} task={t} onToggle={toggle} onDelete={del} />)}
      </div>

      {done.length > 0 && (
        <div className="card">
          <div className="section-header">
            <div className="section-title" style={{ color: "var(--text-muted)" }}>Completed ({done.length})</div>
          </div>
          {done.map(t => <TaskRow key={t.id} task={t} onToggle={toggle} onDelete={del} />)}
        </div>
      )}
    </div>
  );
}

function TaskRow({ task, onToggle, onDelete }) {
  return (
    <div className="task-item">
      <div className={`task-check ${task.completed ? "checked" : ""}`} onClick={() => onToggle(task.id)}>
        {task.completed && <Icon name="check" size={12} color="white" />}
      </div>
      <div style={{ flex: 1 }}>
        <div className={`task-text ${task.completed ? "done" : ""}`}>{task.title}</div>
        {task.dueDate && <div style={{ fontSize: 11, color: "var(--text-muted)", marginTop: 2 }}>Due {task.dueDate}</div>}
      </div>
      <div className="priority-dot" style={{ background: PRIORITY_COLORS[task.priority] }} />
      <span className="badge" style={{ background: CATEGORY_COLORS[task.category]?.bg, color: CATEGORY_COLORS[task.category]?.text }}>{task.category}</span>
      <button className="btn btn-danger btn-sm btn-icon" onClick={() => onDelete(task.id)}><Icon name="trash" size={14} /></button>
    </div>
  );
}

// ── Goals ────────────────────────────────────────────────────────────────────
function GoalsPage({ goals, setGoals, showToast }) {
  const [title, setTitle] = useState("");
  const [category, setCategory] = useState("Personal");
  const [target, setTarget] = useState("");
  const [unit, setUnit] = useState("");
  const [dueDate, setDueDate] = useState("");
  const [showForm, setShowForm] = useState(false);

  const addGoal = () => {
    if (!title.trim() || !target) return;
    setGoals(prev => [...prev, { id: Date.now(), title: title.trim(), category, target: Number(target), progress: 0, unit, dueDate }]);
    setTitle(""); setTarget(""); setUnit(""); setShowForm(false);
    showToast("🎯 Goal created!");
  };

  const updateProgress = (id, delta) =>
    setGoals(prev => prev.map(g => g.id !== id ? g : { ...g, progress: Math.max(0, Math.min(g.target, g.progress + delta)) }));

  const del = (id) => { setGoals(prev => prev.filter(g => g.id !== id)); showToast("🗑️ Goal removed"); };

  return (
    <div className="page-enter">
      {showForm && (
        <div className="card" style={{ marginBottom: 20 }}>
          <div className="section-title" style={{ marginBottom: 16 }}>New Goal</div>
          <div className="form-group">
            <label className="form-label">Goal Title</label>
            <input className="form-input" placeholder="What do you want to achieve?" value={title} onChange={e => setTitle(e.target.value)} autoFocus />
          </div>
          <div className="form-row">
            <div className="form-group">
              <label className="form-label">Category</label>
              <select className="form-input" value={category} onChange={e => setCategory(e.target.value)}>
                {GOAL_CATEGORIES.map(c => <option key={c}>{c}</option>)}
              </select>
            </div>
            <div className="form-group">
              <label className="form-label">Unit (e.g. books, km)</label>
              <input className="form-input" placeholder="books" value={unit} onChange={e => setUnit(e.target.value)} />
            </div>
          </div>
          <div className="form-row">
            <div className="form-group">
              <label className="form-label">Target</label>
              <input className="form-input" type="number" placeholder="12" min="1" value={target} onChange={e => setTarget(e.target.value)} />
            </div>
            <div className="form-group">
              <label className="form-label">Due Date</label>
              <input className="form-input" type="date" value={dueDate} onChange={e => setDueDate(e.target.value)} />
            </div>
          </div>
          <div style={{ display: "flex", gap: 8 }}>
            <button className="btn btn-primary" onClick={addGoal}>Create Goal</button>
            <button className="btn btn-ghost" onClick={() => setShowForm(false)}>Cancel</button>
          </div>
        </div>
      )}

      {!showForm && (
        <button className="btn btn-primary" style={{ marginBottom: 20 }} onClick={() => setShowForm(true)}>
          <Icon name="plus" size={16} color="white" /> New Goal
        </button>
      )}

      {goals.length === 0 && !showForm && (
        <div className="card"><div className="empty"><div className="empty-icon">🎯</div><div className="empty-title">No goals yet</div></div></div>
      )}

      <div className="goals-grid">
        {goals.map(g => {
          const pct = Math.min(100, Math.round((g.progress / g.target) * 100));
          const col = CATEGORY_COLORS[g.category] || CATEGORY_COLORS.Personal;
          return (
            <div className="goal-card" key={g.id}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 12 }}>
                <div>
                  <span className="badge" style={{ background: col.bg, color: col.text, marginBottom: 8, display: "inline-flex" }}>{g.category}</span>
                  <div style={{ fontWeight: 700, fontSize: 15 }}>{g.title}</div>
                  {g.dueDate && <div style={{ fontSize: 11, color: "var(--text-muted)", marginTop: 4 }}>Due {g.dueDate}</div>}
                </div>
                <button className="btn btn-danger btn-icon btn-sm" onClick={() => del(g.id)}><Icon name="trash" size={13} /></button>
              </div>
              <div className="progress-wrap" style={{ marginBottom: 8 }}>
                <div className="progress-fill" style={{ width: `${pct}%`, background: pct >= 100 ? "var(--success)" : "var(--primary)" }} />
              </div>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                <div style={{ fontSize: 13, color: "var(--text-muted)" }}>
                  <strong style={{ color: "var(--text)" }}>{g.progress}</strong> / {g.target} {g.unit}
                </div>
                <div style={{ display: "flex", gap: 4, alignItems: "center" }}>
                  <button className="btn btn-secondary btn-sm" onClick={() => updateProgress(g.id, -1)}>−</button>
                  <span style={{ fontSize: 13, fontWeight: 700, padding: "0 8px", color: pct >= 100 ? "var(--success)" : "var(--primary)" }}>{pct}%</span>
                  <button className="btn btn-primary btn-sm" onClick={() => updateProgress(g.id, 1)}>+</button>
                </div>
              </div>
              {pct >= 100 && (
                <div style={{ marginTop: 10, background: "#ECFDF5", color: "#059669", padding: "8px 12px", borderRadius: 8, fontSize: 13, fontWeight: 600, textAlign: "center" }}>
                  🎉 Goal achieved!
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
}

// ── Calendar ─────────────────────────────────────────────────────────────────
function CalendarPage({ tasks }) {
  const today = new Date();
  const [viewDate, setViewDate] = useState(new Date(today.getFullYear(), today.getMonth(), 1));
  const year = viewDate.getFullYear(), month = viewDate.getMonth();
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const monthName = viewDate.toLocaleString("default", { month: "long", year: "numeric" });
  const taskDates = new Set(tasks.filter(t => t.dueDate).map(t => t.dueDate));
  const cells = [];
  for (let i = 0; i < firstDay; i++) cells.push(null);
  for (let d = 1; d <= daysInMonth; d++) cells.push(d);
  const upcoming = tasks.filter(t => t.dueDate && !t.completed).sort((a, b) => new Date(a.dueDate) - new Date(b.dueDate)).slice(0, 8);

  return (
    <div className="page-enter">
      <div className="dash-grid">
        <div className="card">
          <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 20 }}>
            <div className="section-title">{monthName}</div>
            <div style={{ display: "flex", gap: 8 }}>
              <button className="btn btn-ghost btn-sm" onClick={() => setViewDate(new Date(year, month - 1, 1))}>‹</button>
              <button className="btn btn-ghost btn-sm" onClick={() => setViewDate(new Date(year, month + 1, 1))}>›</button>
            </div>
          </div>
          <div className="cal-grid">
            {["Sun","Mon","Tue","Wed","Thu","Fri","Sat"].map(d => <div className="cal-header-cell" key={d}>{d}</div>)}
            {cells.map((d, i) => {
              if (!d) return <div key={`e-${i}`} />;
              const ds = `${year}-${String(month+1).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
              const isToday = today.getDate()===d && today.getMonth()===month && today.getFullYear()===year;
              return <div key={d} className={`cal-cell in-month ${isToday?"today":""} ${taskDates.has(ds)?"has-task":""}`}>{d}</div>;
            })}
          </div>
        </div>
        <div className="card">
          <div className="section-title" style={{ marginBottom: 16 }}>Upcoming Tasks</div>
          {upcoming.length === 0 && <div className="empty"><div className="empty-icon">📅</div><div className="empty-title">No upcoming tasks</div></div>}
          {upcoming.map(t => (
            <div className="task-item" key={t.id}>
              <div style={{ flex: 1 }}>
                <div style={{ fontSize: 14, fontWeight: 600 }}>{t.title}</div>
                <div style={{ fontSize: 11, color: "var(--text-muted)", marginTop: 2 }}>{t.dueDate}</div>
              </div>
              <span className="badge" style={{ background: CATEGORY_COLORS[t.category]?.bg, color: CATEGORY_COLORS[t.category]?.text }}>{t.category}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

// ── Settings ─────────────────────────────────────────────────────────────────
function SettingsPage({ userName, userEmail, onLogout }) {
  const [notifs, setNotifs] = useState({ email: true, push: false, reminders: true, weekly: true });
  const toggle = (key) => setNotifs(prev => ({ ...prev, [key]: !prev[key] }));

  return (
    <div className="page-enter">
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20 }}>
        <div className="card">
          <div className="section-title" style={{ marginBottom: 20 }}>Account</div>
          <div style={{ display: "flex", alignItems: "center", gap: 16, marginBottom: 24, padding: 16, background: "var(--bg)", borderRadius: 10 }}>
            <div className="user-avatar" style={{ width: 56, height: 56, fontSize: 20 }}>{userName?.[0] || "A"}</div>
            <div>
              <div style={{ fontWeight: 700, fontSize: 16 }}>{userName}</div>
              <div style={{ color: "var(--text-muted)", fontSize: 13 }}>{userEmail}</div>
              <span className="badge" style={{ background: "var(--primary-light)", color: "var(--primary)", marginTop: 6 }}>Pro Account</span>
            </div>
          </div>
          {[["Display Name", userName], ["Email", userEmail], ["Password", "Last changed 30 days ago"]].map(([label, val]) => (
            <div className="setting-row" key={label}>
              <div><div style={{ fontWeight: 600, fontSize: 14 }}>{label}</div><div style={{ fontSize: 13, color: "var(--text-muted)" }}>{val}</div></div>
              <button className="btn btn-secondary btn-sm">Edit</button>
            </div>
          ))}
        </div>

        <div className="card">
          <div className="section-title" style={{ marginBottom: 20 }}>Notifications</div>
          {[
            { key: "email", label: "Email Notifications", desc: "Receive updates via email" },
            { key: "push", label: "Push Notifications", desc: "Browser push alerts" },
            { key: "reminders", label: "Task Reminders", desc: "Reminders before due dates" },
            { key: "weekly", label: "Weekly Summary", desc: "Weekly progress digest" },
          ].map(({ key, label, desc }) => (
            <div className="setting-row" key={key}>
              <div><div style={{ fontWeight: 600, fontSize: 14 }}>{label}</div><div style={{ fontSize: 13, color: "var(--text-muted)" }}>{desc}</div></div>
              <Toggle on={notifs[key]} onToggle={() => toggle(key)} />
            </div>
          ))}
        </div>

        <div className="card">
          <div className="section-title" style={{ marginBottom: 20 }}>Danger Zone</div>
          <div className="setting-row">
            <div><div style={{ fontWeight: 600, fontSize: 14 }}>Sign Out</div><div style={{ fontSize: 13, color: "var(--text-muted)" }}>Log out of your account</div></div>
            <button className="btn btn-danger btn-sm" onClick={onLogout}>Log Out</button>
          </div>
          <div className="setting-row">
            <div><div style={{ fontWeight: 600, fontSize: 14, color: "var(--error)" }}>Delete Account</div><div style={{ fontSize: 13, color: "var(--text-muted)" }}>Permanently remove all data</div></div>
            <button className="btn btn-danger btn-sm">Delete</button>
          </div>
        </div>
      </div>
    </div>
  );
}

// ── App Root ─────────────────────────────────────────────────────────────────
export default function App() {
  const [isLoggedIn, setIsLoggedIn] = useState(false);
  const [userName, setUserName] = useState("");
  const [userEmail, setUserEmail] = useState("");
  const [page, setPage] = useState("dashboard");
  const [tasks, setTasks] = useState(SAMPLE_TASKS);
  const [goals, setGoals] = useState(SAMPLE_GOALS);
  const [toast, setToast] = useState("");

  const showToast = (msg) => { setToast(msg); setTimeout(() => setToast(""), 2500); };
  const logout = () => { setIsLoggedIn(false); setPage("dashboard"); };

  const pageConfig = {
    dashboard: { title: "Dashboard", subtitle: `Good ${new Date().getHours() < 12 ? "morning" : "afternoon"}, ${userName}!` },
    tasks: { title: "Tasks", subtitle: `${tasks.filter(t=>!t.completed).length} pending · ${tasks.filter(t=>t.completed).length} completed` },
    goals: { title: "Goals", subtitle: `${goals.length} active goals in progress` },
    calendar: { title: "Calendar", subtitle: "Your schedule and upcoming deadlines" },
    settings: { title: "Settings", subtitle: "Manage your account and preferences" },
  };

  if (!isLoggedIn) return (
    <><style>{styles}</style><LoginPage onLogin={(email, name) => { setUserEmail(email); setUserName(name); setIsLoggedIn(true); }} /></>
  );

  const { title, subtitle } = pageConfig[page];

  return (
    <>
      <style>{styles}</style>
      <div className="app-shell">
        <Sidebar page={page} setPage={setPage} userName={userName} onLogout={logout} />
        <div className="main">
          <div className="topbar">
            <div>
              <div className="page-title">{title}</div>
              <div className="page-subtitle">{subtitle}</div>
            </div>
            <div className="topbar-actions">
              <button className="btn btn-ghost btn-icon"><Icon name="bell" size={18} color="var(--text-muted)" /></button>
              <button className="btn btn-ghost btn-icon"><Icon name="user" size={18} color="var(--text-muted)" /></button>
            </div>
          </div>
          <div className="content">
            {page === "dashboard" && <Dashboard tasks={tasks} goals={goals} />}
            {page === "tasks"     && <TasksPage tasks={tasks} setTasks={setTasks} showToast={showToast} />}
            {page === "goals"     && <GoalsPage goals={goals} setGoals={setGoals} showToast={showToast} />}
            {page === "calendar"  && <CalendarPage tasks={tasks} />}
            {page === "settings"  && <SettingsPage userName={userName} userEmail={userEmail} onLogout={logout} />}
          </div>
        </div>
      </div>
      <Toast msg={toast} />
    </>
  );
}
