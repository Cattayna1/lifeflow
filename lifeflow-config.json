{
  "projectConfiguration": {
    "projectName": "Lifeflow",
    "version": "1.0.0",
    "description": "A comprehensive life management application for task tracking, goal setting, and personal growth",
    "license": "MIT",
    "author": "Lifeflow Team",
    "repository": {
      "type": "git",
      "url": "https://github.com/yourusername/lifeflow.git"
    }
  },
  "frontendConfiguration": {
    "name": "lifeflow-frontend",
    "version": "1.0.0",
    "private": true,
    "description": "React frontend for Lifeflow application",
    "dependencies": {
      "react": "^17.0.2",
      "react-dom": "^17.0.2",
      "typescript": "^4.4.4",
      "react-scripts": "5.0.0",
      "lucide-react": "^0.263.1",
      "recharts": "^2.5.0"
    },
    "devDependencies": {
      "@testing-library/react": "^12.1.5",
      "@testing-library/jest-dom": "^5.16.5",
      "@testing-library/user-event": "^13.5.0",
      "autoprefixer": "^10.4.14",
      "postcss": "^8.4.24",
      "tailwindcss": "^3.3.2"
    },
    "scripts": {
      "start": "react-scripts start",
      "build": "react-scripts build",
      "test": "react-scripts test",
      "eject": "react-scripts eject"
    },
    "eslintConfig": {
      "extends": [
        "react-app",
        "react-app/jest"
      ]
    },
    "browserslist": {
      "production": [
        ">0.2%",
        "not dead",
        "not op_mini all"
      ],
      "development": [
        "last 1 chrome version",
        "last 1 firefox version",
        "last 1 safari version"
      ]
    },
    "proxy": "http://localhost:5000",
    "homepage": ".",
    "buildConfiguration": {
      "outputDirectory": "build",
      "sourceMap": true,
      "optimization": true
    }
  },
  "backendConfiguration": {
    "name": "lifeflow-backend",
    "version": "1.0.0",
    "description": "Node.js/Express backend for Lifeflow application",
    "main": "index.js",
    "type": "commonjs",
    "dependencies": {
      "express": "^4.17.1",
      "mongoose": "^5.11.15",
      "jsonwebtoken": "^8.5.1",
      "bcryptjs": "^2.4.3",
      "dotenv": "^10.0.0",
      "cors": "^2.8.5",
      "express-validator": "^7.0.0",
      "helmet": "^4.6.0",
      "compression": "^1.7.4",
      "morgan": "^1.10.0"
    },
    "devDependencies": {
      "nodemon": "^2.0.20",
      "jest": "^27.5.1",
      "supertest": "^6.3.3"
    },
    "scripts": {
      "start": "node index.js",
      "dev": "nodemon index.js",
      "test": "jest --detectOpenHandles",
      "test:watch": "jest --watch"
    },
    "engines": {
      "node": ">=14.0.0",
      "npm": ">=6.0.0"
    }
  },
  "databaseConfiguration": {
    "type": "MongoDB",
    "version": "4.0+",
    "connectionString": "mongodb://localhost:27017/lifeflow",
    "atlasConnectionString": "mongodb+srv://username:password@cluster.mongodb.net/lifeflow",
    "collections": {
      "users": {
        "description": "User accounts and authentication",
        "indexes": ["email", "createdAt"]
      },
      "tasks": {
        "description": "User tasks",
        "indexes": ["userId", "dueDate", "category", "completed"]
      },
      "goals": {
        "description": "User goals and progress",
        "indexes": ["userId", "category", "createdAt"]
      },
      "notifications": {
        "description": "User notifications",
        "indexes": ["userId", "read", "sentAt"]
      }
    }
  },
  "environmentVariables": {
    "development": {
      "NODE_ENV": "development",
      "PORT": 5000,
      "MONGODB_URI": "mongodb://localhost:27017/lifeflow",
      "JWT_SECRET": "your_jwt_secret_key",
      "JWT_EXPIRE": "7d",
      "CORS_ORIGIN": "http://localhost:3000"
    },
    "production": {
      "NODE_ENV": "production",
      "PORT": 3000,
      "MONGODB_URI": "mongodb+srv://user:password@cluster.mongodb.net/lifeflow",
      "JWT_SECRET": "your_secure_jwt_secret_key",
      "JWT_EXPIRE": "30d",
      "CORS_ORIGIN": "https://lifeflow.example.com"
    }
  },
  "deploymentConfiguration": {
    "platform": "AWS",
    "services": {
      "frontend": {
        "service": "AWS S3 + CloudFront",
        "description": "Static site hosting for React application",
        "configuration": {
          "bucket": "lifeflow-frontend",
          "distribution": "CloudFront CDN",
          "caching": "Aggressive caching for static assets"
        }
      },
      "backend": {
        "service": "AWS EC2 or Elastic Beanstalk",
        "description": "Node.js/Express server hosting",
        "configuration": {
          "instanceType": "t3.medium",
          "autoScaling": "Enabled",
          "loadBalancer": "Application Load Balancer"
        }
      },
      "database": {
        "service": "MongoDB Atlas",
        "description": "MongoDB cloud database",
        "configuration": {
          "tier": "M5 (500MB minimum)",
          "regions": ["us-east-1"],
          "backups": "Daily",
          "monitoring": "Enabled"
        }
      }
    }
  },
  "gitConfiguration": {
    "gitignore": [
      "# Dependencies",
      "node_modules/",
      "npm-debug.log*",
      "yarn-debug.log*",
      "yarn-error.log*",
      "",
      "# Environment variables",
      ".env",
      ".env.local",
      ".env.production.local",
      ".env.development.local",
      "",
      "# Build outputs",
      "build/",
      "dist/",
      ".next/",
      "out/",
      "",
      "# IDE",
      ".vscode/",
      ".idea/",
      "*.swp",
      "*.swo",
      "*~",
      ".DS_Store",
      "",
      "# Testing",
      ".nyc_output/",
      "coverage/",
      "",
      "# Misc",
      "*.pem",
      "*.log"
    ],
    "branches": {
      "main": "Production-ready code",
      "develop": "Development branch",
      "feature/*": "Feature branches"
    }
  },
  "securityConfiguration": {
    "authentication": {
      "method": "JWT",
      "algorithm": "HS256",
      "expiresIn": "7 days",
      "refreshTokenExpiresIn": "30 days"
    },
    "passwordRequirements": {
      "minLength": 8,
      "requireUppercase": true,
      "requireNumbers": true,
      "requireSpecialCharacters": true
    },
    "cors": {
      "enabled": true,
      "origins": ["http://localhost:3000", "https://lifeflow.example.com"],
      "credentials": true
    },
    "rateLimit": {
      "enabled": true,
      "windowMs": 900000,
      "max": 100,
      "message": "Too many requests from this IP, please try again later."
    },
    "dataProtection": {
      "encryption": "AES-256",
      "tls": "Required",
      "https": "Enforced"
    }
  },
  "testingConfiguration": {
    "unit": {
      "framework": "Jest",
      "coverage": 80,
      "reporter": "coverage"
    },
    "integration": {
      "framework": "Jest + Supertest",
      "apiTesting": "Postman",
      "environment": "staging"
    },
    "e2e": {
      "framework": "Cypress",
      "environment": "staging",
      "browsers": ["chrome", "firefox"]
    }
  },
  "cicdConfiguration": {
    "provider": "GitHub Actions",
    "pipeline": [
      {
        "stage": "Test",
        "steps": [
          "npm install",
          "npm run test",
          "npm run lint"
        ]
      },
      {
        "stage": "Build",
        "steps": [
          "npm run build"
        ]
      },
      {
        "stage": "Deploy",
        "steps": [
          "Deploy to AWS staging",
          "Run smoke tests",
          "Deploy to production"
        ]
      }
    ]
  },
  "performanceConfiguration": {
    "targets": {
      "firstContentfulPaint": "< 1s",
      "largestContentfulPaint": "< 2s",
      "timeToInteractive": "< 3.5s",
      "cumulativeLayoutShift": "< 0.1",
      "totalBlockingTime": "< 200ms"
    },
    "optimizations": [
      "Code splitting",
      "Image optimization",
      "Lazy loading",
      "Minification",
      "Gzip compression",
      "CDN distribution"
    ]
  },
  "scalabilityConfiguration": {
    "targetUsers": "1000 concurrent users",
    "database": {
      "replication": "Enabled",
      "sharding": "Planned",
      "caching": "Redis cache layer"
    },
    "backend": {
      "loadBalancing": "Application Load Balancer",
      "autoScaling": "Based on CPU and memory",
      "containerization": "Docker"
    },
    "frontend": {
      "cdnDistribution": "CloudFront",
      "caching": "Browser + CDN",
      "compression": "Gzip + Brotli"
    }
  },
  "monitoring": {
    "errorTracking": "Sentry",
    "performanceMonitoring": "New Relic",
    "logging": "CloudWatch",
    "uptime": "Pingdom",
    "alerts": {
      "errorRate": "> 1%",
      "responseTime": "> 2s",
      "downtime": "immediate"
    }
  }
}
